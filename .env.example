# LLM API 配置（OpenAI 兼容协议）
# 请复制为 .env 后填入真实密钥，.env 已被 .gitignore 排除不会提交

# 小米大模型（中国集群）
LLM_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
LLM_API_KEY=your-api-key-here
LLM_MODEL=mimo-v2.5-pro

# 其他兼容服务商示例（按需切换）
